# ============================================================
# .env.example
# ローカル開発時のみ使用。本番 (GitHub Actions) では GitHub Secrets を使う。
# このファイルをコピーして .env を作成してください。
# .env は .gitignore に含まれており、リポジトリにはコミットされません。
# ============================================================

# 対象ページの認証パスワード
# 認証が不要なページの場合は空のままでよい
TARGET_PASSWORD=your_password_here

# Slack Incoming Webhook URL
# Slack アプリの設定から取得: https://api.slack.com/apps
# 形式: https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXXXXXXXXXX
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 初回実行時にも Slack 通知を送るか (true / false)
# デフォルト: false (初回は基準値保存のみ、通知しない)
FIRST_RUN_NOTIFY=false

# ログレベル (DEBUG / INFO / WARNING / ERROR)
# デフォルト: INFO
LOG_LEVEL=INFO
